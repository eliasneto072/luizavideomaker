# ===========================================
#  VARIÁVEIS DO DOCKER COMPOSE (raiz)
# ===========================================
# Usadas pelos arquivos docker-compose.yml (produção) e
# docker-compose.dev.yml (desenvolvimento).
#
# Em desenvolvimento, quase tudo tem valor padrão e funciona
# sem preencher. Em PRODUÇÃO, defina todos com valores reais.

# ---------- Banco de dados (PostgreSQL) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_database
POSTGRES_PORT=5432

# ---------- Autenticação (JWT) ----------
# Use uma string longa e aleatória em produção.
JWT_SECRET=troque-esta-chave-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# ---------- URLs ----------
API_URL=http://localhost:3333
FRONTEND_URL=http://localhost:5173

# ---------- Conta administradora (seed) ----------
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=troque-esta-senha

# ---------- Storage (Cloudflare R2) ----------
R2_ACCOUNT_ID=seu-account-id
R2_ACCESS_KEY_ID=seu-access-key-id
R2_SECRET_ACCESS_KEY=seu-secret-access-key
R2_BUCKET_NAME=nome-do-seu-bucket
R2_SIGNED_URL_EXPIRES=900

# ---------- Limpeza automática de galerias ----------
CLEANUP_SECRET=troque-por-um-segredo-aleatorio
CLEANUP_INTERVAL_ENABLED=false
CLEANUP_INTERVAL_HOURS=12
