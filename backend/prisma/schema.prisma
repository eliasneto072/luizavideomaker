// Prisma schema — Luiza Videomaker
// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
//  USUÁRIO (acesso ao painel administrativo)
// ===========================================
// Conta da Luiza para acessar o painel e gerenciar o site.
// O site é público; apenas o painel exige autenticação.
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // hash bcrypt — nunca em texto puro
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  ADMIN
}

// ===========================================
//  MENSAGEM (formulário "Conta sua história")
// ===========================================
// Mensagens enviadas pelos visitantes do site através do
// formulário de contato. Lidas pela Luiza no painel.
model Message {
  id        String        @id @default(uuid())
  name      String // nome de quem enviou
  whatsapp  String? // telefone para retorno (opcional)
  content   String // o conteúdo da mensagem
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@map("messages")
}

enum MessageStatus {
  UNREAD // ainda não lida
  READ // já lida
  ARCHIVED // arquivada
}

// ===========================================
//  PORTFÓLIO (trabalhos em destaque)
// ===========================================
// Trabalhos exibidos no site, gerenciáveis pelo painel.
// Permite trocar vídeos e reordenar sem mexer no código.
model Portfolio {
  id         String   @id @default(uuid())
  title      String // título do trabalho
  category   String // Casamento, Imobiliário, Petshop, etc.
  videoUrl   String?  @map("video_url") // link do reel/vídeo
  coverImage String?  @map("cover_image") // imagem de capa
  order      Int      @default(0) // ordem de exibição
  active     Boolean  @default(true) // controla se aparece no site
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([active, order])
  @@map("portfolio")
}

// ===========================================
//  DEPOIMENTO (feedbacks de clientes)
// ===========================================
// Depoimentos exibidos no site, gerenciáveis pelo painel.
model Testimonial {
  id        String   @id @default(uuid())
  author    String // nome do cliente
  role      String? // "Noivos", "Petshop parceiro", etc.
  content   String // o depoimento
  order     Int      @default(0) // ordem de exibição
  active    Boolean  @default(true) // controla se aparece no site
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active, order])
  @@map("testimonials")
}

// ===========================================
//  GALERIA (entrega de material ao cliente)
// ===========================================
// Galeria privada criada pela Luiza para entregar fotos e vídeos a um
// cliente. O acesso é feito por link único + senha, sem necessidade de
// conta. Cada galeria expira após um período (padrão: 60 dias).
model Gallery {
  id           String        @id @default(uuid())
  title        String // ex.: "Casamento Marina & João"
  clientName   String        @map("client_name") // nome do cliente
  slug         String        @unique // código único do link (ex.: x7k9m2p4)
  passwordHash String        @map("password_hash") // senha da galeria (hash bcrypt)
  coverImage   String?       @map("cover_image") // imagem de capa (opcional)
  status       GalleryStatus @default(ACTIVE)
  expiresAt    DateTime      @map("expires_at") // data de expiração
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  files GalleryFile[] // arquivos pertencentes à galeria

  @@index([slug])
  @@index([status, expiresAt])
  @@map("galleries")
}

enum GalleryStatus {
  ACTIVE // disponível para o cliente
  EXPIRED // passou da data de expiração
  ARCHIVED // arquivada manualmente pela Luiza
}

// Arquivo (foto ou vídeo) pertencente a uma galeria.
// Os binários ficam no Cloudflare R2; aqui guardamos apenas os
// metadados e as chaves de acesso ao storage.
model GalleryFile {
  id        String  @id @default(uuid())
  galleryId String  @map("gallery_id")
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  type         FileType
  fileName     String  @map("file_name") // nome original do arquivo
  storageKey   String  @map("storage_key") // chave do objeto no R2
  thumbnailKey String? @map("thumbnail_key") // chave da miniatura (fotos)
  sizeBytes    BigInt  @map("size_bytes") // tamanho em bytes
  width        Int? // largura (para layout do grid)
  height       Int? // altura
  order        Int     @default(0) // ordem de exibição
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([galleryId])
  @@map("gallery_files")
}

enum FileType {
  PHOTO
  VIDEO
}
