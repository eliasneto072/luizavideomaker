# ===========================================
#  AMBIENTE DA APLICAÇÃO
# ===========================================
# Define o modo de execução: development | production
NODE_ENV=development

# Porta em que a API vai rodar
PORT=3333

# URL base da API (usada em links e integrações)
API_URL=http://localhost:3333

# URL do frontend (usada para liberar CORS)
FRONTEND_URL=http://localhost:5173


# ===========================================
#  BANCO DE DADOS (PostgreSQL)
# ===========================================
# String de conexão completa do Postgres.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_database?schema=public"


# ===========================================
#  AUTENTICAÇÃO (JWT)
# ===========================================
# Chave secreta para assinar os tokens. Use uma string longa e aleatória.
JWT_SECRET="troque-esta-chave-por-uma-string-longa-e-aleatoria"

# Tempo de expiração do token (ex.: 7d, 24h, 60m)
JWT_EXPIRES_IN="7d"


# ===========================================
#  CONTA ADMINISTRADORA (seed inicial)
# ===========================================
# Dados usados pelo seed para criar a conta de acesso ao painel.
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@exemplo.com"
ADMIN_PASSWORD="troque-esta-senha"


# ===========================================
#  STORAGE DE ARQUIVOS (Cloudflare R2)
# ===========================================
# Credenciais do Cloudflare R2, usadas para armazenar as fotos e vídeos
# das galerias. Obtidas no painel da Cloudflare ao criar um API Token
# com permissão "Object Read & Write".

# ID da sua conta Cloudflare (aparece no topo da página do R2).
R2_ACCOUNT_ID="seu-account-id"

# Chave de acesso do API Token.
R2_ACCESS_KEY_ID="seu-access-key-id"

# Chave secreta do API Token (mostrada apenas uma vez na criação!).
R2_SECRET_ACCESS_KEY="seu-secret-access-key"

# Nome do bucket criado para as galerias.
R2_BUCKET_NAME="nome-do-seu-bucket"

# Validade (em segundos) das URLs assinadas de download/visualização.
# Padrão: 900 (15 minutos).
R2_SIGNED_URL_EXPIRES=900